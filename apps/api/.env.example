# ─── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ─── Database (Neon PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="generate-a-strong-random-secret-min-64-chars"

# ─── Frontend URL (for CORS) ───────────────────────────────────────────────────
WEB_URL="https://your-app.vercel.app"

# ─── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET="solarcredit-docs"

# ─── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="TradeFinance <hello@yourdomain.com>"

# ─── Dojah (BVN + CAC verification) ───────────────────────────────────────────
DOJAH_APP_ID=""
DOJAH_SECRET_KEY=""

# ─── FirstCentral Credit Bureau ────────────────────────────────────────────────
FIRSTCENTRAL_BASE_URL=""
FIRSTCENTRAL_API_KEY=""
FIRSTCENTRAL_CLIENT_ID=""
